# MEXC API credentials (leave blank for paper trading)
MEXC_API_KEY=
MEXC_SECRET=

# Trading mode: paper | live
TRADING_MODE=paper

# Starting capital in USDT
STARTING_CAPITAL=500

# Leverage (1-20x, be careful)
LEVERAGE=10

# Max risk per trade as % of capital (e.g. 1.5 = 1.5%)
RISK_PER_TRADE_PCT=1.5

# Daily loss limit as % of capital (bot halts if hit)
DAILY_LOSS_LIMIT_PCT=3.0

# Profit target in USDT (bot logs when reached)
PROFIT_TARGET_USDT=500

# Pairs to scan (comma-separated MEXC futures symbols)
TRADING_PAIRS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT,BNB/USDT:USDT

# Minimum confluence score (0-7) -- 4 recommended
MIN_CONFLUENCE_SCORE=4

# Minimum rule-engine confidence to place trade (0-100) -- 65 recommended
MIN_AI_CONFIDENCE=65

# Timeframe for candles -- 5m recommended (less noise than 1m)
TIMEFRAME=5m

# Log level: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
